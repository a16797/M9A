{
    "scripts": {
        "format:json": "prettier --write \"**/*.json\"",
        "format:py": "uv run --frozen black .",
        "format:all": "prettier --write \"**/*.json\" && uv run --frozen black .",
        "lint:py": "uv run --frozen ruff check .",
        "typecheck": "uv run --frozen pyright",
        "test": "uv run --frozen pytest",
        "check": "uv run --frozen ruff check . && uv run --frozen pyright && uv run --frozen pytest",
        "install:py": "uv sync --frozen --group dev"
    },
    "devDependencies": {
        "@nekosu/maa-tools": "1.0.24",
        "@nekosu/prettier-plugin-maafw-sort": "^1.0.5",
        "prettier": "3.5.3",
        "prettier-plugin-multiline-arrays": "4.1.4",
        "pyright": "^1.1.400"
    }
}
