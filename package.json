{
    "name": "m9a",
    "version": "0.0.0",
    "license": "AGPL-3.0-or-later",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@11.9.0",
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "format:json": "prettier --write \"**/*.json\"",
        "format:py": "uv run --frozen black .",
        "format:all": "prettier --write \"**/*.json\" && uv run --frozen black .",
        "lint:py": "uv run --frozen ruff check .",
        "typecheck": "uv run --frozen pyright",
        "test": "uv run --frozen pytest",
        "check:py": "uv run --frozen ruff check . && uv run --frozen pyright && uv run --frozen pytest",
        "check:schema": "node tools/validate-schema.mjs",
        "check:maa": "maa-tools check",
        "check": "uv run --frozen ruff check . && uv run --frozen pyright && uv run --frozen pytest && node tools/validate-schema.mjs && maa-tools check",
        "install:py": "uv sync --frozen --group dev"
    },
    "devDependencies": {
        "@nekosu/maa-tools": "1.0.24",
        "@nekosu/prettier-plugin-maafw-sort": "^1.0.5",
        "prettier": "3.5.3",
        "prettier-plugin-multiline-arrays": "4.1.4",
        "pyright": "^1.1.400"
    }
}
